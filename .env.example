# GROQ_API_KEY: Required for Groq AI API calls.
GROQ_API_KEY="MY_GROQ_API_KEY"

# Optional: choose the Groq model used by the app.
GROQ_MODEL="llama-3.3-70b-versatile"

# Supabase variables for the Vite client.
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-publishable-key"

# APP_URL: The URL where this app is hosted.
APP_URL="MY_APP_URL"
